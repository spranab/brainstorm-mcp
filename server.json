{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.spranab/brainstorm-mcp",
  "description": "Multi-model AI brainstorming debates with code review and quick perspectives",
  "repository": {
    "url": "https://github.com/spranab/brainstorm-mcp",
    "source": "github"
  },
  "version": "1.5.3",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "brainstorm-mcp",
      "version": "1.5.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "OpenAI API key for GPT models (optional — not needed in hosted mode)",
          "isRequired": false,
          "format": "string",
          "isSecret": true,
          "name": "OPENAI_API_KEY"
        },
        {
          "description": "Google Gemini API key (optional)",
          "isRequired": false,
          "format": "string",
          "isSecret": true,
          "name": "GEMINI_API_KEY"
        },
        {
          "description": "DeepSeek API key (optional)",
          "isRequired": false,
          "format": "string",
          "isSecret": true,
          "name": "DEEPSEEK_API_KEY"
        }
      ]
    }
  ]
}
